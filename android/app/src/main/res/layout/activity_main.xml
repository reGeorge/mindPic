<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context=".MainActivity">

    <!-- 顶部标题栏（含保存按钮） -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/titleBar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="#2196F3"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="mindPic"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:gravity="center_vertical"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toLeftOf="@id/btnSave"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintHorizontal_bias="0.5"/>

        <ImageButton
            android:id="@+id/btnSave"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_save"
            android:tint="#FFFFFF"
            android:contentDescription="保存图片"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginRight="8dp"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 输入框和一键清空按钮容器 -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/textInputLayout"
        style="@style/Widget.MindPic.TextInputLayout.OutlinedBox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/titleBar"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginTop="32dp"
        android:layout_marginLeft="32dp"
        android:layout_marginRight="32dp"
        app:boxBackgroundMode="outline"
        app:boxCornerRadiusTopStart="16dp"
        app:boxCornerRadiusTopEnd="16dp"
        app:boxCornerRadiusBottomStart="16dp"
        app:boxCornerRadiusBottomEnd="16dp"
        app:endIconMode="clear_text">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="请输入描述"
            android:background="@android:color/transparent"
            android:padding="16dp"
            android:textSize="18sp"
            android:inputType="textMultiLine"
            android:gravity="top|start"
            android:minLines="2"
            android:maxLines="5" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- 图片预览区域（支持手势） -->
    <ImageView
        android:id="@+id/ivPreview"
        android:layout_width="0dp"
        android:layout_height="180dp"
        android:scaleType="centerCrop"
        android:src="@android:drawable/ic_menu_gallery"
        android:background="#EEEEEE"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toBottomOf="@id/textInputLayout"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginTop="24dp"
        android:layout_marginLeft="32dp"
        android:layout_marginRight="32dp" />

    <!-- 段落切换按钮和指示器 -->
    <LinearLayout
        android:id="@+id/segmentNavBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/ivPreview"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">

        <Button
            android:id="@+id/btnPrevSegment"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="上一段" />

        <TextView
            android:id="@+id/tvSegmentIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1/1"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:textSize="16sp"/>

        <Button
            android:id="@+id/btnNextSegment"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="下一段" />
    </LinearLayout>

    <!-- 字体选择（平铺单选） -->
    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/groupFont"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/segmentNavBar"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginTop="16dp"
        android:layout_marginLeft="32dp"
        android:layout_marginRight="32dp"
        app:singleSelection="true">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFont1"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="韶华体"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFont2"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="洒脱体"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFont3"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="上上谦体"/>
    </com.google.android.material.button.MaterialButtonToggleGroup>

    <!-- 背景选择（平铺单选） -->
    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/groupBg"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/groupFont"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginTop="8dp"
        android:layout_marginLeft="32dp"
        android:layout_marginRight="32dp"
        app:singleSelection="true">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBg3"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="叶子"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBg1"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="月亮1"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBg2"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="月亮2"/>
        
    </com.google.android.material.button.MaterialButtonToggleGroup>

    <!-- 对齐方式选择（平铺单选） -->
    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/groupAlign"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/groupBg"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginTop="8dp"
        android:layout_marginLeft="32dp"
        android:layout_marginRight="32dp"
        app:singleSelection="true">
        
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAlignLeft"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="左对齐"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAlignCenter"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="居中"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAlignRight"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="右对齐"/>
    </com.google.android.material.button.MaterialButtonToggleGroup>

    <!-- 字体大小选择（SeekBar） -->
    <TextView
        android:id="@+id/tvSizeLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="字号：80"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/groupAlign"
        app:layout_constraintLeft_toLeftOf="parent"
        android:layout_marginTop="16dp"
        android:layout_marginLeft="32dp" />

    <SeekBar
        android:id="@+id/seekBarSize"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:max="270"
        android:progress="120"
        app:layout_constraintTop_toBottomOf="@id/tvSizeLabel"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginTop="8dp"
        android:layout_marginLeft="32dp"
        android:layout_marginRight="32dp"
        android:progressTint="@color/colorPrimary" />

    <TextView
        android:id="@+id/tvOffsetXLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="水平偏移：0"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/seekBarSize"
        app:layout_constraintLeft_toLeftOf="parent"
        android:layout_marginTop="16dp"
        android:layout_marginLeft="32dp" />

    <SeekBar
        android:id="@+id/seekBarOffsetX"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:max="600"
        android:progress="300"
        app:layout_constraintTop_toBottomOf="@id/tvOffsetXLabel"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginTop="8dp"
        android:layout_marginLeft="32dp"
        android:layout_marginRight="32dp"
        android:progressTint="@color/colorPrimary" />

    <!-- 悬浮分享按钮 -->

    <!-- 底部版本号 -->
    <TextView
        android:id="@+id/tvVersion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v1.0.0"
        android:textColor="#888888"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginBottom="16dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
