<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context=".MainActivity">

    <!-- 顶部 Material3 工具栏 -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/topAppBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/colorPrimary"
        android:title="mindPic"
        android:titleTextColor="@android:color/white"/>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:layout_marginBottom="80dp"
        android:layout_marginTop="56dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 输入区 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp">
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/textInputLayout"
                        style="@style/Widget.MindPic.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:boxBackgroundMode="outline"
                        app:boxCornerRadiusTopStart="16dp"
                        app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp"
                        app:boxCornerRadiusBottomEnd="16dp"
                        app:endIconMode="clear_text">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="请输入描述"
                            android:background="@android:color/transparent"
                            android:padding="16dp"
                            android:textSize="18sp"
                            android:inputType="textMultiLine"
                            android:gravity="top|start"
                            android:minLines="1"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>
                </com.google.android.material.card.MaterialCardView>
                <ImageButton
                    android:id="@+id/btnToggleExpand"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:background="@android:color/transparent"
                    android:src="@android:drawable/arrow_down_float"
                    android:contentDescription="展开/折叠"
                    android:tint="@color/colorPrimary" />
            </LinearLayout>

            <!-- 图片预览区 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">
                    <ImageView
                        android:id="@+id/ivPreview"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:scaleType="centerCrop"
                        android:src="@android:drawable/ic_menu_gallery"
                        android:background="#EEEEEE"
                        android:adjustViewBounds="true"
                        app:layout_constraintDimensionRatio="1:1" />
                    <com.google.android.material.tabs.TabLayout
                        android:id="@+id/tabSegment"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:tabIndicatorColor="@color/colorPrimary"
                        app:tabSelectedTextColor="@color/colorPrimary"
                        app:tabTextColor="@android:color/darker_gray" />
                    <TextView
                        android:id="@+id/tvSegmentIndicator"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1/1"
                        android:textSize="14sp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="4dp" />
                    <!-- 段落切换按钮 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="8dp">
                        <Button
                            android:id="@+id/btnPrevSegment"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="上一段"/>
                        <Button
                            android:id="@+id/btnNextSegment"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="下一段"
                            android:layout_marginStart="16dp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 样式调整区 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">
                    <TextView
                        android:id="@+id/tvSizeLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="字号：60"
                        android:textSize="16sp" />
                    <com.google.android.material.slider.Slider
                        android:id="@+id/seekBarSize"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:valueFrom="30"
                        android:valueTo="100"
                        android:value="60"
                        app:trackColorActive="@color/colorPrimary"
                        app:trackColorInactive="@android:color/darker_gray" />
                    <TextView
                        android:id="@+id/tvOffsetXLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="水平偏移：0"
                        android:textSize="16sp"
                        android:layout_marginTop="8dp" />
                    <com.google.android.material.slider.Slider
                        android:id="@+id/seekBarOffsetX"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:valueFrom="-1200"
                        android:valueTo="1200"
                        android:value="0"
                        app:trackColorActive="@color/colorPrimary"
                        app:trackColorInactive="@android:color/darker_gray" />
                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/groupAlign"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:singleSelection="true">
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAlignLeft"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="左对齐"/>
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAlignCenter"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="居中"/>
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAlignRight"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="右对齐"/>
                    </com.google.android.material.button.MaterialButtonToggleGroup>
                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/groupFont"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:singleSelection="true">
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFont1"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="韶华体"/>
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFont2"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="洒脱体"/>
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFont3"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="上上谦体"/>
                    </com.google.android.material.button.MaterialButtonToggleGroup>
                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/groupBg"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:singleSelection="true">
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnBg3"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="叶子"/>
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnBg1"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="月亮1"/>
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnBg2"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="月亮2"/>
                    </com.google.android.material.button.MaterialButtonToggleGroup>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <View
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:background="@android:color/transparent" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- 悬浮保存按钮 -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnSave"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@android:drawable/ic_menu_save"
        app:backgroundTint="@color/colorPrimary"
        app:iconTint="@android:color/white"
        app:rippleColor="@color/colorPrimaryVariant"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:contentDescription="保存图片" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
